# ============================================
# İsim Şehir Katman — Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=katmanisimsehir
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3007

# Admin
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_EMAIL=admin@katmanisimsehir.com
ADMIN_INITIAL_PASSWORD=change_this_admin_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cleanup Jobs
ROOM_INACTIVE_MINUTES=30
CHAT_RETENTION_DAYS=7
SESSION_CLEANUP_HOURS=1
