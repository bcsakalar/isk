{
  "name": "katmanisimsehir",
  "version": "1.0.0",
  "description": "İsim Şehir Katman - Real-time multiplayer Turkish word game with retro pixel aesthetics",
  "main": "server/index.js",
  "homepage": "https://github.com/bcsakalar/katmanisimsehir#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcsakalar/katmanisimsehir.git"
  },
  "bugs": {
    "url": "https://github.com/bcsakalar/katmanisimsehir/issues"
  },
  "author": "bcsakalar",
  "license": "MIT",
  "keywords": [
    "isim-sehir",
    "word-game",
    "multiplayer",
    "socket-io",
    "nodejs",
    "express",
    "postgresql",
    "turkish-game",
    "real-time",
    "retro-gaming"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "migrate": "node server/db/migrate.js",
    "seed": "node server/db/seed.js",
    "css:build": "npx tailwindcss -i ./client/css/tailwind.css -o ./client/css/output.css --minify",
    "css:watch": "npx tailwindcss -i ./client/css/tailwind.css -o ./client/css/output.css --watch",
    "docker:dev": "docker compose -p isk -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -p isk -f docker-compose.dev.yml down",
    "docker:prod": "docker compose -p isk -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -p isk -f docker-compose.prod.yml down",
    "docker:logs": "docker compose -p isk -f docker-compose.prod.yml logs -f app --tail=100",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "validate": "npm run lint && npm test"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsdom": "^26.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17"
  },
  "overrides": {
    "tar": "^7.5.11"
  }
}
